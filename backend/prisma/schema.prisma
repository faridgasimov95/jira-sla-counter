generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int         @id @default(autoincrement())
  email               String      @unique
  password            String
  createdAt           DateTime    @default(now())
  settings            Settings?
  savedFiles          SavedFile[]
}

model Settings{
  id                  Int         @id @default(autoincrement())
  userId              Int         @unique
  user                User        @relation(fields: [userId], references: [id])
  jiraSubdomain       String?
  jiraUsername        String?
  jiraToken           String?
  ignoredStatusCodes  Int[]
  priorityThresholds  Json?
  country             String?
  excelPassword       String?
}

model SavedFile{
  id                  Int         @id @default(autoincrement())
  userId              Int         @unique
  user                User        @relation(fields: [userId], references: [id])
  savedAt             DateTime    @default(now())
  filename            String
  filedata            Bytes
}